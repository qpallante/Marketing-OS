# ───────────────────────────────────────────────────────────────
# Marketing OS — core-api environment variables
# Copia in .env e popola con valori reali (da Doppler in produzione).
# ───────────────────────────────────────────────────────────────

# Application
APP_NAME="Marketing OS — Core API"
APP_VERSION=0.0.0
ENVIRONMENT=dev
DEBUG=true

# Database (Postgres / Supabase)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/marketing_os

# Redis (Celery broker + cache)
REDIS_URL=redis://localhost:6379/0

# JWT — vedi ADR-0003
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# Refresh token TTL: 7 in dev/staging (catch breakage early), 30 in production.
REFRESH_TOKEN_TTL_DAYS=7

# AI providers — vedi ADR-0008 §AI stack
# In .env reale (gitignored) usare le key vere; qui SOLO placeholder vuoti.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# AI models (default sensati, override solo se serve)
# Sonnet 4.6 = cost/quality bilanciato per RAG. Opus 4.7 per task complessi.
ANTHROPIC_MODEL=claude-sonnet-4-6
# text-embedding-3-small = 1536-dim, $0.02/1M tokens
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# DEVE corrispondere a vector(N) su brand_chunks.embedding (migration 0004)
EMBEDDING_DIM=1536

# Storage locale per PDF caricati. Path relativo a core-api/ (dev) o
# absolute. Auto-creato al startup. Gitignored. Migration a Supabase
# Storage in S+. Vedi ADR-0008.
BRAND_ASSETS_DIR=storage/brand_assets

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# CORS (comma-separated list will be parsed into JSON array)
# Dev locale: 3001 per evitare conflitto con altri progetti che usano 3000
CORS_ORIGINS=["http://localhost:3001"]

# Frontend URL (per costruire link invitation, password reset, ecc.)
# Dev locale: 3001. In production: https://app.marketing-os.com (o equivalente)
FRONTEND_URL=http://localhost:3001
