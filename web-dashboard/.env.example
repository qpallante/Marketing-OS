# ───────────────────────────────────────────────────────────────
# Marketing OS — web-dashboard environment variables
# Copia in .env.local (auto-gitignored da Next.js) e popola.
# Solo server-side: NESSUNA var con prefisso NEXT_PUBLIC_*.
# ───────────────────────────────────────────────────────────────

# URL del core-api FastAPI. Il browser non lo conosce mai (BFF pattern):
# le chiamate passano da Next.js Server Actions / Route Handlers.
BACKEND_URL=http://localhost:8001

# Porta su cui Next.js dev server ascolta. Default 3000 è occupato da altri
# progetti dell'utente — usiamo 3001. Lo script "dev" in package.json passa
# già --port 3001, ma settando PORT qui copriamo anche `next start` e tools
# che leggono l'env. Vedi CLAUDE.md §"Stack tecnologico".
PORT=3001
